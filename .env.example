# Microtek IDM environment configuration.
# Copy to .env and adjust. Values shown are the in-code defaults unless marked
# REQUIRED. The backend validates these on startup (server/src/models/configSchemas.js).

# Core
NODE_ENV=development
PORT=4000

# REQUIRED — no default. Postgres connection string.
DATABASE_URL=postgres://microtek_idm:microtek_idm@localhost:5432/microtek_idm

# Frontend origin allowed by CORS.
CORS_ORIGIN=http://localhost:5173

# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

#  Auth
# Min 32 chars. The default below is a development-only secret and MUST be
# overridden in production (startup fails if left as the default in prod).
AUTH_TOKEN_SECRET=development-auth-secret-change-before-production
AUTH_SESSION_TTL_SECONDS=28800

#  Redis
# Required in production, where it must be rediss:// (TLS) or a loopback address.
REDIS_URL=redis://localhost:6379

#  Integration
# HMAC secret for the SAP production-import webhook (POST /api/idm-01/import/production).
# Min 32 chars. REQUIRED IN PRODUCTION: if unset, the webhook signature check
# silently passes and accepts unsigned payloads.
IMPORT_WEBHOOK_SECRET=

#  Background jobs
# Ageing snapshot refresh interval in ms (default 12h).
AGEING_REFRESH_INTERVAL_MS=43200000

#  Rate limiting
# General API limiter.
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=600
SCAN_RATE_LIMIT_WINDOW_MS=60000
SCAN_RATE_LIMIT_MAX=240

# Trusted proxy hops in front of the app, or "true"/"false". Set this when behind
# a proxy/load balancer so request.ip (used for IP-keyed rate limiting) is correct.
TRUST_PROXY=false

#  Frontend (Vite)
# Read by the client build, not the backend.
VITE_API_BASE_URL=http://localhost:4000/api
